ALPHA_CONFIG_PATH=~/.alpha-agent/config.toml
ALPHA_DB_PATH=~/.alpha-agent/alpha.db
ALPHA_LOG_DIR=~/.alpha-agent/logs
ALPHA_GATEWAY_STATUS_PATH=~/.alpha-agent/gateway-status.json
ALPHA_LLM_PROVIDER=mock
ALPHA_LLM_MODEL=
ALPHA_COMPATIBLE_BASE_URL=https://api.openai.com/v1
ALPHA_COMPATIBLE_API_KEY=
ALPHA_DEEPSEEK_API_KEY=
ALPHA_DEEPSEEK_REASONING_ENABLED=true
ALPHA_DEEPSEEK_REASONING_EFFORT=
ALPHA_CODEX_ACCESS_TOKEN=
ALPHA_FILE_TOOL_ENABLED=true
ALPHA_FILE_TOOL_ALLOWED_ROOTS=.
ALPHA_FILE_TOOL_PATCH_ENABLED=false
ALPHA_FILE_TOOL_WRITE_ROOTS=
ALPHA_COGNITION_BACKGROUND_ENABLED=true
ALPHA_COGNITION_BACKGROUND_STARTUP_DELAY_SECONDS=5
ALPHA_COGNITION_BACKGROUND_INTERVAL_SECONDS=300
ALPHA_COGNITION_BACKGROUND_TICK_TIMEOUT_SECONDS=60
ALPHA_COGNITION_BACKGROUND_INTAKE_BATCH_SIZE=64
ALPHA_COGNITION_BACKGROUND_INTAKE_MIN_SOURCES=1
ALPHA_COGNITION_BACKGROUND_EXTRACTION_BATCH_SIZE=12
ALPHA_COGNITION_BACKGROUND_EXTRACTION_MIN_SOURCES=1
ALPHA_COGNITION_BACKGROUND_CONSOLIDATION_BATCH_SIZE=12
ALPHA_COGNITION_BACKGROUND_CONSOLIDATION_MIN_DRAFTS=1
ALPHA_COGNITION_BACKGROUND_CONFLICT_BATCH_SIZE=4
ALPHA_COGNITION_BACKGROUND_CONFLICT_MIN_CONFLICTS=1
ALPHA_COGNITION_BACKGROUND_SUMMARY_BATCH_SIZE=4
ALPHA_COGNITION_BACKGROUND_SUMMARY_INITIAL_MIN_BELIEFS=12
ALPHA_COGNITION_BACKGROUND_SUMMARY_CHANGED_SOURCE_MIN=6
ALPHA_COGNITION_BACKGROUND_SUMMARY_INVALIDATED_SOURCE_MIN=1
ALPHA_WORKING_MEMORY_LIMIT=12
ALPHA_RETRIEVAL_LIMIT=8
